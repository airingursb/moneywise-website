---
import type { I18nData } from '../content.config';
import { PRICING } from '../config/site';
import AppStoreBadge from './AppStoreBadge.astro';

interface Props {
  t: I18nData;
}
const { t } = Astro.props;

const fmt = (n: number) => new Intl.NumberFormat('en-US', { style: 'currency', currency: PRICING.pro.currency, minimumFractionDigits: 2 }).format(n);
---

<section id="pricing" class="py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="max-w-2xl">
      <p class="text-[11px] uppercase tracking-[0.12em] text-[var(--color-accent-primary)] font-semibold">{t.pricing.eyebrow}</p>
      <h2 class="mt-3 font-[family-name:var(--font-display)] font-bold text-[36px] md:text-[44px] leading-[1.05] tracking-[-0.025em] text-[var(--color-fg-primary)]">
        {t.pricing.title}
      </h2>
      <p class="mt-5 text-[17px] leading-[1.6] text-[var(--color-fg-secondary)]">{t.pricing.subhead}</p>
    </div>
    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl">
      <article class="rounded-2xl border border-[var(--color-border)] bg-white p-8 flex flex-col">
        <h3 class="text-[22px] font-bold text-[var(--color-fg-primary)]">{t.pricing.free_name}</h3>
        <p class="mt-2 text-[14px] text-[var(--color-fg-secondary)]">{t.pricing.free_tagline}</p>
        <div class="mt-6 font-[family-name:var(--font-mono)] text-[40px] font-bold text-[var(--color-fg-primary)]">$0</div>
        <ul class="mt-6 space-y-3 flex-1">
          {t.pricing.free_features.map((f) => (
            <li class="flex gap-3 text-[14px] text-[var(--color-fg-primary)]">
              <span class="text-[var(--color-accent-primary)] font-bold">✓</span>
              <span>{f}</span>
            </li>
          ))}
        </ul>
        <div class="mt-8">
          <AppStoreBadge variant="primary" label={t.pricing.cta_free} comingSoonLabel={t.hero.coming_soon} />
        </div>
      </article>
      <article class="rounded-2xl border-2 border-[var(--color-accent-primary)] bg-white p-8 flex flex-col relative">
        <div class="absolute top-5 right-5 rounded-full bg-[var(--color-accent-primary)]/10 text-[var(--color-accent-primary)] text-[11px] font-semibold px-3 py-1 uppercase tracking-wider">Pro</div>
        <h3 class="text-[22px] font-bold text-[var(--color-fg-primary)]">{t.pricing.pro_name}</h3>
        <p class="mt-2 text-[14px] text-[var(--color-fg-secondary)]">{t.pricing.pro_tagline}</p>
        <div class="mt-6 flex items-baseline gap-2">
          <span class="font-[family-name:var(--font-mono)] text-[40px] font-bold text-[var(--color-fg-primary)]">{fmt(PRICING.pro.priceMonthly)}</span>
          <span class="text-[14px] text-[var(--color-fg-secondary)]">{t.pricing.per_month}</span>
        </div>
        <p class="mt-1 text-[12px] text-[var(--color-fg-secondary)]">
          or {fmt(PRICING.pro.priceAnnual)}{t.pricing.per_year}
        </p>
        <ul class="mt-6 space-y-3 flex-1">
          {t.pricing.pro_features.map((f) => (
            <li class="flex gap-3 text-[14px] text-[var(--color-fg-primary)]">
              <span class="text-[var(--color-accent-primary)] font-bold">✓</span>
              <span>{f}</span>
            </li>
          ))}
        </ul>
        <div class="mt-8">
          <AppStoreBadge variant="primary" label={t.pricing.cta_pro} comingSoonLabel={t.hero.coming_soon} />
        </div>
      </article>
    </div>
  </div>
</section>
