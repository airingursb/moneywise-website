---
import type { I18nData } from '../content.config';

interface Props {
  t: I18nData;
}
const { t } = Astro.props;

const iconColors = [
  '#E8F5E9', '#E3F2FD', '#FFF3E0', '#F3E5F5', '#E8EAF6', '#E8F5E9',
];
const iconText = ['◆', '▲', '●', '▼', '■', '★'];
---

<section id="features" class="bg-[var(--color-surface-secondary)] py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="max-w-2xl">
      <p class="text-[11px] uppercase tracking-[0.12em] text-[var(--color-accent-primary)] font-semibold">
        {t.features.eyebrow}
      </p>
      <h2 class="mt-3 font-[family-name:var(--font-display)] font-bold text-[36px] md:text-[44px] leading-[1.05] tracking-[-0.025em] text-[var(--color-fg-primary)]">
        {t.features.title}
      </h2>
    </div>
    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {t.features.items.map((item, i) => (
        <article class="rounded-2xl bg-white border border-[var(--color-border)] p-6 transition hover:shadow-[0_8px_24px_rgba(30,51,34,0.06)]">
          <div
            class="w-10 h-10 rounded-xl flex items-center justify-center text-[var(--color-accent-primary)] font-bold"
            style={`background:${iconColors[i]}`}
          >
            {iconText[i]}
          </div>
          <h3 class="mt-4 text-[17px] font-semibold text-[var(--color-fg-primary)]">{item.title}</h3>
          <p class="mt-2 text-[14px] leading-[1.6] text-[var(--color-fg-secondary)]">{item.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
