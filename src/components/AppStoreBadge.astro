---
import { SITE } from '../config/site';

interface Props {
  variant?: 'primary' | 'light' | 'dark';
  label: string;
  comingSoonLabel: string;
  class?: string;
}

const { variant = 'primary', label, comingSoonLabel, class: className = '' } = Astro.props;
const available = SITE.appStoreAvailable;

const styles = {
  primary: 'bg-[var(--color-surface-inverse)] text-white hover:opacity-90',
  light:   'bg-white text-[var(--color-surface-inverse)] hover:bg-white/90',
  dark:    'bg-[var(--color-surface-inverse)] text-white hover:opacity-90',
}[variant];
---

{available ? (
  <a
    href={SITE.appStoreUrl}
    data-umami-event="app_store_cta_click"
    class={`inline-flex items-center gap-2 px-6 py-3.5 rounded-xl font-semibold text-sm transition ${styles} ${className}`}
  >
    {label}
    <span aria-hidden="true">→</span>
  </a>
) : (
  <span
    class={`inline-flex items-center gap-2 px-6 py-3.5 rounded-xl font-semibold text-sm opacity-60 cursor-not-allowed ${styles} ${className}`}
    title={comingSoonLabel}
  >
    {comingSoonLabel}
  </span>
)}
