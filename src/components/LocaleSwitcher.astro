---
import type { Locale } from '../config/site';
import { LOCALE_LABELS, LOCALES } from '../config/site';
import { pathFor } from '../lib/i18n';

interface Props {
  current: Locale;
  slug: string;
}

const { current, slug } = Astro.props;
---

<div class="relative inline-block">
  <details class="group">
    <summary class="list-none cursor-pointer flex items-center gap-1.5 text-sm text-[var(--color-fg-primary)] hover:text-[var(--color-accent-primary)] transition">
      <span>{LOCALE_LABELS[current]}</span>
      <span aria-hidden="true" class="text-xs opacity-60">▾</span>
    </summary>
    <div class="absolute right-0 mt-2 min-w-[140px] rounded-xl border border-[var(--color-border)] bg-white shadow-lg py-1 z-50">
      {LOCALES.map((l) => (
        <a
          href={pathFor(l, slug)}
          data-umami-event="locale_switch"
          data-umami-event-from={current}
          data-umami-event-to={l}
          class={`block px-4 py-2 text-sm transition ${l === current ? 'text-[var(--color-accent-primary)] font-semibold' : 'text-[var(--color-fg-primary)] hover:bg-[var(--color-surface-secondary)]'}`}
        >
          {LOCALE_LABELS[l]}
        </a>
      ))}
    </div>
  </details>
</div>
