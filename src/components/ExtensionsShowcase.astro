---
import type { Locale } from '../config/site';
import type { I18nData } from '../content.config';

interface Props {
  locale: Locale;
  t: I18nData;
}
const { locale, t } = Astro.props;
---

<section class="bg-[var(--color-surface-inverse)] text-white py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="max-w-3xl">
      <p class="text-[11px] uppercase tracking-[0.12em] text-[var(--color-trend-green)] font-semibold">
        {t.extensions.eyebrow}
      </p>
      <h2 class="mt-3 font-[family-name:var(--font-display)] font-bold text-[36px] md:text-[44px] leading-[1.05] tracking-[-0.025em]">
        {t.extensions.title_part1}<em
          class="font-[family-name:var(--font-serif-italic)] not-italic [font-style:italic] font-medium text-[var(--color-trend-green)]"
        >{t.extensions.title_italic}</em>{t.extensions.title_part2}
      </h2>
      <p class="mt-5 text-[17px] leading-[1.6] text-white/75">{t.extensions.subhead}</p>
    </div>

    <!-- Three-pillar grid (matches PrivacyFirst rhythm) -->
    <div class="mt-14 grid grid-cols-1 md:grid-cols-3 gap-8">
      {t.extensions.pillars.map((p, i) => (
        <div class="rounded-2xl border border-white/15 p-6 bg-white/[0.03]">
          <div class="flex items-center gap-3">
            <span class="inline-flex items-center justify-center w-9 h-9 rounded-lg bg-[var(--color-trend-green)]/15 text-[var(--color-trend-green)]">
              {/* Pillar icons: server, key, plug. Inline so we don't ship an icon font. */}
              {i === 0 && (
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="3" y="4" width="18" height="6" rx="1.5" />
                  <rect x="3" y="14" width="18" height="6" rx="1.5" />
                  <line x1="7" y1="7" x2="7.01" y2="7" />
                  <line x1="7" y1="17" x2="7.01" y2="17" />
                </svg>
              )}
              {i === 1 && (
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="8" cy="14" r="4" />
                  <path d="m11 11 8-8" />
                  <path d="m17 5 3 3" />
                  <path d="m14 8 3 3" />
                </svg>
              )}
              {i === 2 && (
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M9 2v6" />
                  <path d="M15 2v6" />
                  <path d="M6 8h12v4a6 6 0 0 1-12 0Z" />
                  <path d="M12 18v4" />
                </svg>
              )}
            </span>
            <h3 class="text-[18px] font-semibold">{p.title}</h3>
          </div>
          <p class="mt-3 text-[14px] leading-[1.65] text-white/70">{p.description}</p>
        </div>
      ))}
    </div>

    <!-- Tested-clients chips -->
    <div class="mt-12 flex flex-wrap items-center gap-3">
      <span class="text-[11px] uppercase tracking-[0.12em] text-white/55 font-semibold mr-1">
        {t.extensions.clients_label}
      </span>
      {t.extensions.clients.map((c) => (
        <span class="inline-flex items-center px-3 py-1.5 rounded-full border border-white/15 bg-white/[0.03] text-[13px] text-white/80">
          {c}
        </span>
      ))}
    </div>
  </div>
</section>
