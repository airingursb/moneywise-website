---
import type { Locale } from '../config/site';
import type { I18nData } from '../content.config';

interface Props {
  locale: Locale;
  t: I18nData;
}
const { locale, t } = Astro.props;

// Mac App Store screenshots are landscape (2880×1800) and already include
// the macOS window chrome (traffic lights + titlebar). We don't wrap them
// in a phone-style mockup — just display them with rounded corners and a
// soft editorial shadow that matches the rest of the page.
const macFiles = [
  '01-dashboard.png',
  '02-records.png',
  '05-investments.png',
  '07-advisor.png',
  '09-asset-report.png',
];
// Mac shots ship in all 5 site locales. The captures themselves are
// largely English (sidebar labels are hardcoded in the desktop shell),
// but the AI Advisor chat content and a handful of localized strings
// (Asset Report titles, dates, currency) DO change per locale, and the
// editorial overlay text outside the window is fully translated.
const macLocale = locale;
---

<section class="bg-[var(--color-surface)] py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="max-w-3xl">
      <p class="text-[11px] uppercase tracking-[0.12em] text-[var(--color-accent-primary)] font-semibold">
        {t.mac.eyebrow}
      </p>
      <h2 class="mt-3 font-[family-name:var(--font-display)] font-bold text-[36px] md:text-[44px] leading-[1.05] tracking-[-0.025em] text-[var(--color-fg-primary)]">
        {t.mac.title_part1}<em
          class="font-[family-name:var(--font-serif-italic)] not-italic [font-style:italic] font-medium text-[var(--color-accent-primary)]"
        >{t.mac.title_italic}</em>{t.mac.title_part2}
      </h2>
      <p class="mt-5 text-[17px] leading-[1.6] text-[var(--color-fg-secondary)]">
        {t.mac.subhead}
      </p>
    </div>
  </div>

  <!-- Hero shot: dashboard, full-width band -->
  <div class="mt-12 mx-auto max-w-6xl px-6">
    <figure>
      <div class="rounded-[18px] overflow-hidden shadow-[0_32px_80px_rgba(30,51,34,0.18),0_0_0_1px_rgba(0,0,0,0.05)] bg-[#1d1d1d]">
        <img
          src={`/screenshots/mac/${macLocale}/${macFiles[0]}`}
          alt={t.mac.captions[0]}
          loading="lazy"
          decoding="async"
          class="block w-full h-auto"
          width="2048"
          height="1440"
        />
      </div>
      <figcaption class="mt-3 px-1 text-[13px] text-[var(--color-fg-secondary)]">
        {t.mac.captions[0]}
      </figcaption>
    </figure>
  </div>

  <!-- Remaining 4 shots: 2-up grid on desktop, single column on mobile -->
  <div class="mt-10 mx-auto max-w-6xl px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {macFiles.slice(1).map((file, i) => (
        <figure>
          <div class="rounded-[14px] overflow-hidden shadow-[0_18px_40px_rgba(30,51,34,0.14),0_0_0_1px_rgba(0,0,0,0.05)] bg-[#1d1d1d]">
            <img
              src={`/screenshots/mac/${macLocale}/${file}`}
              alt={t.mac.captions[i + 1]}
              loading="lazy"
              decoding="async"
              class="block w-full h-auto"
              width="2048"
              height="1440"
            />
          </div>
          <figcaption class="mt-3 px-1 text-[13px] text-[var(--color-fg-secondary)]">
            {t.mac.captions[i + 1]}
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
