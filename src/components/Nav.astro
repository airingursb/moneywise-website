---
import type { Locale } from '../config/site';
import type { I18nData } from '../content.config';
import { pathFor } from '../lib/i18n';
import LocaleSwitcher from './LocaleSwitcher.astro';

interface Props {
  locale: Locale;
  slug: string;
  t: I18nData;
}

const { locale, slug, t } = Astro.props;
---

<header
  class="sticky top-0 z-40 backdrop-blur-md bg-white/85 border-b border-[var(--color-border)]"
>
  <nav class="mx-auto max-w-6xl px-6 py-4 flex items-center justify-between">
    <a href={pathFor(locale)} class="flex items-center gap-2">
      <img src="/app-icon.png" alt="" width="28" height="28" class="rounded-[7px]" />
      <span class="text-[17px] font-bold tracking-tight">MoneyWise</span>
    </a>
    <div class="flex items-center gap-6 text-[13px]">
      <a href={pathFor(locale, 'features')} class="hover:text-[var(--color-accent-primary)] transition">{t.nav.features}</a>
      <a href={pathFor(locale, 'privacy')} class="hover:text-[var(--color-accent-primary)] transition">{t.nav.privacy}</a>
      <a href={`${pathFor(locale)}#pricing`} class="hover:text-[var(--color-accent-primary)] transition">{t.nav.pricing}</a>
      <a href={`${pathFor(locale)}#download`} class="text-[var(--color-accent-primary)] font-semibold hover:underline">{t.nav.download}</a>
      <LocaleSwitcher current={locale} slug={slug} />
    </div>
  </nav>
</header>
