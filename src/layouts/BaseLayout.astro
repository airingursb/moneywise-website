---
import '../styles/global.css';
import SeoHead from '../components/SeoHead.astro';
import { SITE } from '../config/site';
import type { Locale } from '../config/site';

interface Props {
  title: string;
  description: string;
  locale: Locale;
  slug?: string;
}

const { title, description, locale, slug = '' } = Astro.props;
---

<!DOCTYPE html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#2D6B3F" />
    <SeoHead title={title} description={description} locale={locale} slug={slug} />
    <script
      is:inline
      defer
      src={SITE.umamiScriptUrl}
      data-website-id={SITE.umamiWebsiteId}
    ></script>
    <script is:inline>
      (function() {
        function identify() {
          if (typeof umami === 'undefined' || typeof umami.identify !== 'function') return;
          var lang = document.documentElement.lang || 'en';
          var visited = localStorage.getItem('mw_visited');
          var returning = visited ? 'yes' : 'no';
          if (!visited) localStorage.setItem('mw_visited', '1');
          umami.identify({ language: lang, returning: returning });
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', function () { setTimeout(identify, 500); });
        } else {
          setTimeout(identify, 500);
        }
      })();
    </script>
  </head>
  <body class="bg-[var(--color-surface-primary)] text-[var(--color-fg-primary)]">
    <slot />
  </body>
</html>
