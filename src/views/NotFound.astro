---
import type { Locale } from '../config/site';
import { getI18n, pathFor } from '../lib/i18n';
import BaseLayout from '../layouts/BaseLayout.astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = await getI18n(locale);
---

<BaseLayout title="Not found · MoneyWise" description="Page not found." locale={locale} slug="404">
  <main class="min-h-screen flex flex-col items-center justify-center text-center px-6">
    <p class="font-[family-name:var(--font-mono)] text-[14px] tracking-[0.2em] uppercase text-[var(--color-fg-secondary)]">404</p>
    <h1 class="mt-4 font-[family-name:var(--font-display)] font-bold text-[48px] leading-[1.1] tracking-[-0.03em] text-[var(--color-fg-primary)]">Not found.</h1>
    <p class="mt-3 text-[16px] text-[var(--color-fg-secondary)]">The page you're looking for doesn't exist.</p>
    <a href={pathFor(locale)} class="mt-8 inline-block px-6 py-3 rounded-xl bg-[var(--color-accent-primary)] text-white font-semibold text-sm">
      Back to home
    </a>
  </main>
</BaseLayout>
